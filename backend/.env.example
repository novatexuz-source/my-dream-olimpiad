# Django settings
SECRET_KEY=generate-a-random-50-char-string-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com

# Database (Supabase Session Pooler or Direct URL - NOT Transaction Pooler 6543)
# Example: postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:5432/postgres
DATABASE_URL=

# Telegram bot
BOT_TOKEN=your-bot-token-from-botfather

# Admin account (REQUIRED in production — migrations create/rotate the admin from these)
ADMIN_USERNAME=+998901234567
ADMIN_PASSWORD=set-a-strong-password-here

# Frontend registration form URL (used in Telegram inline buttons)
WEBAPP_URL=https://your-frontend.vercel.app/register

# CORS / CSRF (production only - comma-separated origins)
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
CSRF_TRUSTED_ORIGINS=https://your-frontend.vercel.app,https://your-backend.onrender.com
